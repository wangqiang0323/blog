@import '../../../assets/style/johnson'

$menu-width = 250px
$menu-bg-color = #454955

.card
    margin-bottom: 0
    background: $menu-bg-color   
    border-top: none
    .card-header
        background: $menu-bg-color
    a
        color: #999
        font-size: 14px
        &:hover,
        &:link
            text-decoration: none
            font-size: 14px
    .card-block
        padding: 0
        ul
            padding: 0
            margin: 0
            li
                list-style: none
                padding 0.75rem
                border-bottom 1px solid rgba(0,0,0,0.125)
                padding-left: 40px
                &:hover, 
                &:active,
                &.active    
                    background: lighten($menu-bg-color, 10)
                    a
                        color: #FFF
                    i
                        color $brand-vanke